# Webhook URLs (scanners use these)
WEBHOOK_DEFAULT=https://discord.com/api/webhooks/...
WEBHOOK_DIABLO4=https://discord.com/api/webhooks/...
WEBHOOK_POE2=https://discord.com/api/webhooks/...
WEBHOOK_POE1=https://discord.com/api/webhooks/...

# Platform-specific webhook URLs (optional, overrides game routing)
ELDO_WEBHOOK_URL=
G2G_WEBHOOK_URL=

# Coordinator (Discord bot)
BOT_TOKEN=
CHANNEL_IDS=id1,id2,id3
ELDO_WORKER_CHANNEL_ID=
G2G_WORKER_CHANNEL_ID=

# Worker HTTP endpoints (Coordinator dispatches tasks here)
WORKER_ELDO_URL=http://localhost:8001
WORKER_G2G_URL=http://localhost:8002
WORKER_ELDO_PORT=8001
WORKER_G2G_PORT=8002

# Chrome / Selenium
CHROME_BINARY_PATH=
HEADLESS_MODE=false

# Database (shared by all processes)
DATABASE_PATH=data/orders.db

# G2G API mode (set to true to use REST API instead of Selenium)
G2G_USE_API=false

# Eldorado API mode (set to true to use REST API instead of Selenium)
ELDO_USE_API=false

# Auth service (captures JWT/cookies, runs as separate process)
AUTH_SERVICE_URL=http://localhost:8010
AUTH_PORT=8010

# Scanner filter (blacklist-first, then whitelist). See docs/order_filtering.md.
# Default since 2026-06-27: allow-all (whitelist empty). Only the bulk/placeholder
# gear listings the worker can't fulfil ("Any Gears", "Any Items - Aspects") and
# service spam (Boosting/Leveling/Account/Custom oder) are dropped. Specific gear
# (Mageblood, Headhunter...) now flows to ERP for hand delivery.
SCANNER_WHITELIST=
SCANNER_BLACKLIST=Any Gears, Any Items - Aspects, Boosting, Leveling, Account, Custom oder
SCAN_INTERVAL_MIN=15
SCAN_INTERVAL_MAX=25

# Manual paste (ERP-triggered, on-demand). ERP (.100) POSTs {order_id} to paste ONE
# specific order bypassing the keyword filter. Each scanner exposes its own port.
# MANUAL_PASTE_SECRET must match the value ERP sends in the X-Manual-Secret header.
# See docs/manual_paste.md.
MANUAL_PASTE_SECRET=
MANUAL_PASTE_PORT_G2G=8771
MANUAL_PASTE_PORT_ELDO=8772

# G2G Auto-login credentials (for dashboard OTP relay)
G2G_EMAIL=
G2G_PASSWORD=

# Dashboard web UI
DASHBOARD_PORT=8766
